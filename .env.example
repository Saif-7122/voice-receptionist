# ── Vapi ──────────────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_PUBLIC_KEY=

# ── LLM (Groq) ────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── TTS (ElevenLabs) ──────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Escalation ────────────────────────────────────────────────────────────
OWNER_PHONE=
TWILIO_SMS_NUMBER=

# ── Langfuse Observability ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ───────────────────────────────────────────────────────────────────
# Set to your Render URL in production, e.g. https://your-app.onrender.com
BACKEND_URL=http://localhost:8000

# ── Frontend (Next.js — prefix with NEXT_PUBLIC_ for browser access) ──────
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
